# --- WordPress site URLs (use your final domain) ---
WP_HOME=https://gfoss.it
WP_SITEURL=https://gfoss.it
FORCE_SSL_ADMIN=true

# --- Database (change all secrets before deploy) ---
MYSQL_DATABASE=gfoss_wp
MYSQL_USER=gfoss
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_ROOT_PASSWORD=replace-with-very-strong-root-password

# --- Debug ---
WP_DEBUG=0

# --- Nginx Proxy Manager docker network ---
# Run `docker network ls` on the VPS, then put the NPM network name here.
# The wordpress container joins this external network so NPM can reach it.
NPM_NETWORK_NAME=npm-net

# --- SMTP (production) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@gfoss.it
SMTP_FROM_NAME=GFOSS.it APS

# --- Association data ---
GFOSS_QUOTA_AMOUNT=30
GFOSS_IBAN=IT85F0306909606100000015079
PAYPAL_HOSTED_BUTTON_ID=AQKXPZ2EHSP34
# Email del conto PayPal dell'associazione (destinatario dei pagamenti).
# OBBLIGATORIO: l'IPN rifiuta i pagamenti se il receiver_email non corrisponde.
PAYPAL_RECEIVER_EMAIL=tesoreria@gfoss.it

# --- Spazio dati GIS dei soci (PostGIS + GeoServer) ---
# Lasciare vuoto per disattivare il servizio. Il container WordPress deve essere
# sulla stessa rete docker dei container PostGIS/GeoServer (vedi docs/deploy.md):
#   docker network connect <rete-postgis> gfoss-wp
#
# PostGIS — un DB condiviso con estensione postgis, schema per socio.
# Crea prima un ruolo admin dedicato (CREATEROLE, NON superuser) e il DB:
#   CREATE ROLE gfoss_provisioner LOGIN PASSWORD '...' CREATEROLE;
#   CREATE DATABASE soci_gis OWNER gfoss_provisioner;
#   \c soci_gis  ->  CREATE EXTENSION postgis;  REVOKE CREATE ON SCHEMA public FROM PUBLIC;
GFOSS_PG_HOST=postgis            # host del container PostGIS visto da WordPress
GFOSS_PG_PORT=5432
GFOSS_PG_ADMIN_DB=soci_gis
GFOSS_PG_ADMIN_USER=gfoss_provisioner
GFOSS_PG_ADMIN_PASS=
GFOSS_PG_PUBLIC_HOST=gfoss.it    # host mostrato ai soci per QGIS/ogr2ogr (es. dominio + porta esposta)
GFOSS_PG_PUBLIC_PORT=5432
GFOSS_PG_INTERNAL_HOST=postgis   # host PostGIS visto DA GeoServer (di solito = GFOSS_PG_HOST)

# GeoServer — REST API admin
GFOSS_GEOSERVER_URL=http://geoserver:8080/geoserver
GFOSS_GEOSERVER_PUBLIC_URL=https://geoserver.gfoss.it/geoserver
GFOSS_GEOSERVER_ADMIN_USER=admin
GFOSS_GEOSERVER_ADMIN_PASS=
