# Copia in .env nella stessa cartella e compila. NON committare il .env reale.
NC_DOMAIN=cloud.gfoss.it
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=cambia-questa-password-forte
NC_DB_PASSWORD=cambia-password-db
NC_DB_ROOT_PASSWORD=cambia-password-root-db
# Rete/range da cui arriva NPM (di default copre le subnet docker private).
NC_TRUSTED_PROXIES=172.16.0.0/12
# Nome della rete docker esterna di Nginx Proxy Manager (controlla con: docker network ls)
NPM_NETWORK_NAME=npm-net
